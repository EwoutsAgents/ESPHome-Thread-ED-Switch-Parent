--- src/core/thread/mle.cpp
+++ src/core/thread/mle.cpp
@@
 Error Mle::SearchForBetterParent(void)
 {
     Error error = kErrorNone;
     VerifyOrExit(IsChild(), error = kErrorInvalidState);
     mAttacher.Attach(kBetterParent);
 exit:
     return error;
 }
+
+Error Mle::SearchForPreferredParentRloc16(uint16_t aParentRloc16)
+{
+    Error error = kErrorNone;
+    VerifyOrExit(IsChild(), error = kErrorInvalidState);
+    SuccessOrExit(error = mAttacher.AttachToPreferredParentRloc16(aParentRloc16));
+exit:
+    return error;
+}
+
+Error Mle::SearchForPreferredParentExtAddress(const otExtAddress &aParentExtAddress)
+{
+    Error error = kErrorNone;
+    VerifyOrExit(IsChild(), error = kErrorInvalidState);
+    SuccessOrExit(error = mAttacher.AttachToPreferredParentExtAddress(aParentExtAddress));
+exit:
+    return error;
+}
+
+Error Mle::SetPreferredParentRloc16(uint16_t aParentRloc16)
+{
+    return mAttacher.SetPreferredParentRloc16(aParentRloc16);
+}
+
+Error Mle::SetPreferredParentExtAddress(const otExtAddress &aParentExtAddress)
+{
+    return mAttacher.SetPreferredParentExtAddress(aParentExtAddress);
+}
+
+void Mle::ClearPreferredParent(void)
+{
+    mAttacher.ClearPreferredParent();
+}
@@
 Mle::Attacher::Attacher(Instance &aInstance)
     : InstanceLocator(aInstance)
+    , mPreferredParentIdentifierType(kPreferredParentNone)
+    , mPreferredParentRloc16(kInvalidRloc16)
+    , mPreferredParentSelectionActive(false)
 {
+    memset(&mPreferredParentExtAddress, 0, sizeof(mPreferredParentExtAddress));
 }
+
+Error Mle::Attacher::SetPreferredParentRloc16(uint16_t aParentRloc16)
+{
+    Error error = kErrorNone;
+    VerifyOrExit(aParentRloc16 != kInvalidRloc16, error = kErrorInvalidArgs);
+    mPreferredParentIdentifierType = kPreferredParentRloc16;
+    mPreferredParentRloc16 = aParentRloc16;
+    mPreferredParentSelectionActive = true;
+exit:
+    return error;
+}
+
+Error Mle::Attacher::SetPreferredParentExtAddress(const otExtAddress &aParentExtAddress)
+{
+    mPreferredParentIdentifierType = kPreferredParentExtAddress;
+    mPreferredParentExtAddress = aParentExtAddress;
+    mPreferredParentSelectionActive = true;
+    return kErrorNone;
+}
+
+void Mle::Attacher::ClearPreferredParent(void)
+{
+    mPreferredParentIdentifierType = kPreferredParentNone;
+    mPreferredParentRloc16 = kInvalidRloc16;
+    memset(&mPreferredParentExtAddress, 0, sizeof(mPreferredParentExtAddress));
+    mPreferredParentSelectionActive = false;
+}
+
+Error Mle::Attacher::AttachToPreferredParentRloc16(uint16_t aParentRloc16)
+{
+    Error error = kErrorNone;
+    VerifyOrExit(!IsAttaching(), error = kErrorBusy);
+    SuccessOrExit(error = SetPreferredParentRloc16(aParentRloc16));
+    Attach(kPreferredParent);
+exit:
+    return error;
+}
+
+Error Mle::Attacher::AttachToPreferredParentExtAddress(const otExtAddress &aParentExtAddress)
+{
+    Error error = kErrorNone;
+    VerifyOrExit(!IsAttaching(), error = kErrorBusy);
+    SuccessOrExit(error = SetPreferredParentExtAddress(aParentExtAddress));
+    Attach(kPreferredParent);
+exit:
+    return error;
+}
