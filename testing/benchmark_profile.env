# Fixed device mapping for all benchmark runs
CHILD_PORT=/dev/serial/by-id/usb-1a86_USB_Single_Serial_5AF7094229-if00

# Two-router benchmark pair
# - ROUTER_PRIMARY_PORT (R1): initial parent for all scenarios
# - ROUTER_SECONDARY_PORT (R2): target/fallback parent
ROUTER_PRIMARY_PORT=/dev/serial/by-id/usb-1a86_USB_Single_Serial_5AF7094336-if00
ROUTER_SECONDARY_PORT=/dev/serial/by-id/usb-1a86_USB_Single_Serial_5AF7094169-if00

# Optional extra routers (not used by default runner)
ROUTER_C_PORT=/dev/serial/by-id/usb-1a86_USB_Single_Serial_5AF7094169-if00
ROUTER_D_PORT=/dev/serial/by-id/usb-1a86_USB_Single_Serial_5AF7094229-if00

# Thread dataset values used in all benchmark YAMLs
THREAD_CHANNEL=15
THREAD_PAN_ID=0x1234
THREAD_NETWORK_KEY=0x00112233445566778899aabbccddeeff
THREAD_EXT_PAN_ID=0x1111222233334444
THREAD_NETWORK_NAME=OpenClawBench
THREAD_PSKC=0x445566778899aabbccddeeff00112233
THREAD_MESH_LOCAL_PREFIX=fd11:22::/64

# Parent-switch target used for both Variant B modes
# Real parent candidate observed in captures (replace if your topology changes)
TARGET_PARENT_EXTADDR=4645b099670a43ed

# USB Thread preconditioning for steady variant runs
# Follows VARIANT_PRECONDITION_TIMEOUT unless explicitly overridden by the caller.
VARIANT_USB_THREAD_OFF_TIMEOUT="${VARIANT_USB_THREAD_OFF_TIMEOUT:-${VARIANT_PRECONDITION_TIMEOUT:-45}}"
