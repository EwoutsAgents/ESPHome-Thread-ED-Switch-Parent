# Fixed device mapping for all benchmark runs
CHILD_PORT=/dev/serial/by-id/usb-1a86_USB_Single_Serial_5AF7094208-if00
ROUTER_A_PORT=/dev/serial/by-id/usb-1a86_USB_Single_Serial_5AF7094336-if00
ROUTER_B_PORT=/dev/serial/by-id/usb-1a86_USB_Single_Serial_5AF7094210-if00
ROUTER_C_PORT=/dev/serial/by-id/usb-1a86_USB_Single_Serial_5AF7094169-if00
ROUTER_D_PORT=/dev/serial/by-id/usb-1a86_USB_Single_Serial_5AF7094229-if00

# Keep this identical across router + child configs
THREAD_TLV=<THREAD_TLV_SHARED_BY_ALL_NODES>

# Parent-switch target used for both Variant B modes
TARGET_PARENT_EXTADDR=00124b0001abcdef
